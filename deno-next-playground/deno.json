{
  "nodeModulesDir": "auto",
  "unstable": ["unsafe-proto", "sloppy-imports"],
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "strict": true,
    "jsx": "preserve"
  },
  "tasks": {
    "dev": "deno run -A --unstable-detect-cjs npm:next@16.2.0 dev",
    "build": "deno run -A --unstable-detect-cjs npm:next@16.2.0 build",
    "start": "deno run -A --unstable-detect-cjs npm:next@16.2.0 start"
  }
}
